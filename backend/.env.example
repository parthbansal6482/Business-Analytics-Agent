# backend/.env.example — copy to .env and fill in values

# === REQUIRED ===
# Get your free API key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_key_from_aistudio_google_com

# === SERVICES (defaults match docker-compose.yml) ===
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379
POSTGRES_URL=postgresql+asyncpg://user:password@localhost:5432/ecomm_agent

# === SHOPIFY (optional — only if testing OAuth) ===
SHOPIFY_API_KEY=your_shopify_app_api_key
SHOPIFY_API_SECRET=your_shopify_app_secret
SHOPIFY_REDIRECT_URI=http://localhost:8000/api/shopify/callback

# === FRONTEND ===
FRONTEND_URL=http://localhost:5173
