# --- GROQ CONFIGURATION ---
# Use multiple keys separated by commas for automatic rotation to bypass rate limits
# Example: GROQ_API_KEY=gsk_abc123,gsk_xyz789
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- RETRIEVAL & ANALYSIS SETTINGS ---
# Both are set to 30 to ensure consistent data counts in the UI
QUICK_MODE_TOP_K=30
DEEP_MODE_TOP_K=30

# --- DATA INGESTION & SYNTHESIS ---
# Set to 'false' if you want new uploads to append to existing data
DELETE_BEFORE_UPLOAD=true

# Token budget controls to stay within Groq TPM limits
MAX_CHUNK_CHARS=200
MAX_DATA_BLOCK_CHARS=6000

# --- DATABASE & INFRASTRUCTURE ---
REDIS_URL=redis://redis:6379/0
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Database configuration (Matches docker-compose defaults)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=ecomm_agent
DATABASE_URL=postgresql://user:password@postgres:5432/ecomm_agent

# --- DEPLOYMENT ---
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000
