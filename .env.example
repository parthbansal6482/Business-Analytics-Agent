# ─────────────────────────────────────────────────────────
# E-Commerce Intelligence Agent - Environment Template
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Usage: cp .env.example .env

# 🤖 LLM PROVIDER CONFIGURATION (GROQ ONLY)
# ------------------------------------------
LLM_PROVIDER=groq

# 💡 PRO TIP: You can provide multiple Groq API keys separated by commas 
# to overcome rate limits (Key Rotation). e.g., key1,key2,key3
GROQ_API_KEY=your_groq_key_1,your_groq_key_2

# Fastest & most reliable model for this agent
GROQ_MODEL=llama-3.3-70b-versatile

# 🌍 APP NETWORK URLS
# ------------------------------------------
# Local Development (Docker defaults)
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000

# For Production (Uncomment and update)
# FRONTEND_URL=https://analytics.yourdomain.com
# VITE_API_URL=https://api.yourdomain.com

# 🗄️ DATABASE & INFRASTRUCTURE (Docker Defaults)
# ------------------------------------------
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=ecomm_agent
POSTGRES_URL=postgresql+asyncpg://user:password@postgres:5432/ecomm_agent

QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379

# 🛍️ SHOPIFY INTEGRATION (Optional)
# ------------------------------------------
SHOPIFY_API_KEY=your_shopify_app_api_key
SHOPIFY_API_SECRET=your_shopify_app_api_secret
SHOPIFY_REDIRECT_URI=http://localhost:8000/api/shopify/callback

# ⚙️ AGENT TUNING
# ------------------------------------------
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
QUICK_MODE_TOP_K=10
DEEP_MODE_TOP_K=30

# Token budget limiters (prevents rate limit hits on long queries)
MAX_CHUNK_CHARS=200
MAX_DATA_BLOCK_CHARS=6000
