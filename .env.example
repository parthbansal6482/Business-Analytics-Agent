# ==========================================
# E-Commerce Intelligence Agent Environment
# ==========================================
# Copy this file to '.env' in the same folder as docker-compose.yml 
# and fill in your actual API keys.

# ------------------------------------------
# PostgreSQL Database Settings
# ------------------------------------------
POSTGRES_USER=ecomm_user
POSTGRES_PASSWORD=ecomm_secure_pw
POSTGRES_DB=ecomm_agent

# ------------------------------------------
# LLM Provider Configuration
# ------------------------------------------
# Supported providers: groq, gemini, openrouter
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# If you use Gemini:
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=your_google_api_key_here

# ------------------------------------------
# Agent Tuning & Behavior
# ------------------------------------------
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Retrieval boundaries (how many data chunks the LLM sees)
QUICK_MODE_TOP_K=10
DEEP_MODE_TOP_K=30
RERANK_TOP_K=15

# Token budget limiters (prevents rate limit hits on long queries)
MAX_CHUNK_CHARS=200
MAX_DATA_BLOCK_CHARS=6000

# ------------------------------------------
# Shopify Integration (Optional)
# ------------------------------------------
# If not connecting real Shopify stores, leave default values
SHOPIFY_API_KEY=your_shopify_app_api_key
SHOPIFY_API_SECRET=your_shopify_app_api_secret
SHOPIFY_REDIRECT_URI=http://localhost:8000/api/shopify/callback

# ------------------------------------------
# App Network URLs (Docker Defaults)
# ------------------------------------------
# These are handled by docker-compose, but can be customized if needed.
# FRONTEND_URL=http://localhost:5173
# QDRANT_URL=http://qdrant:6333
# REDIS_URL=redis://redis:6379
# POSTGRES_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
